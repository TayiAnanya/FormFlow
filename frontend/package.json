{
  "name": "formflow",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
  "test:e2e": "playwright test --project=chromium",
  "test:e2e:smoke": "playwright test --project=chromium --grep \"@smoke|@critical\"",
  "test:e2e:smoke-only": "playwright test --project=chromium --grep \"@smoke\"",
  "test:e2e:critical-only": "playwright test --project=chromium --grep \"@critical\"",
  "test:e2e:quality": "playwright test --project=chromium e2e/quality/specs",
  "test:e2e:report": "playwright show-report",
  "test:chromium": "playwright test --project=chromium",
  "test:firefox": "playwright test --project=firefox",
  "test:webkit": "playwright test --project=webkit",
  "test:cross-browser": "playwright test --project=chromium --project=firefox --project=webkit"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.25",
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "@primeng/themes": "^20.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "pdfjs-dist": "^4.10.38",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.31",
    "@angular/cli": "^20.3.31",
    "@angular/compiler-cli": "^20.3.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^26.1.1",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.2"
  }
}
